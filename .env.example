# Required — get your API key from app.rule.io > Settings > API keys
RULE_IO_API_KEY=your-api-key-here

# Optional — set to "true" to enable debug logging
# RULE_IO_DEBUG=true

# Optional — prefix for subscriber field groups (default: "Booking")
# RULE_IO_FIELD_GROUP_PREFIX=Booking

# Optional — override API base URLs (for testing or staging)
# RULE_IO_BASE_URL_V2=
# RULE_IO_BASE_URL_V3=
